OPENAI_API_KEY=your_open_api_key_here
# --- MCP Server (profile_lookup) ---
BASE_MCP_SERVER_URL=http://localhost:8090/mcp/
BASE_MCP_SERVER_TRANSPORT=streamable_http

# --- Logging ---
LOG_DIR=./logs

# --- LangSmith (optional) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=

# --- Config paths ---
CONFIG_PATH=./Resources/dev.yaml
MODELS_PATH=./Resources/models.yaml
MESSAGES_PATH=./Resources/messages.yaml
PROMPTS_PATH=./Resources/prompts.yaml
AGENTS_PATH=./Resources/agents.yaml
