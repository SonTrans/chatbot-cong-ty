# --- LLM Service ---
LLM_SERVICE_HOST=
LLM_SERVICE_HTTP_PORT=
LLM_SERVICE_API_KEY=
LLM_MODEL_PROVIDER=openai
LLM_MODEL_NAME=KNM/Knm3.5-4B
# --- MCP Server (profile_lookup) ---
BASE_MCP_SERVER_URL=http://localhost:8090/mcp/
BASE_MCP_SERVER_TRANSPORT=streamable_http

# --- Logging ---
LOG_DIR=./logs

# --- LangSmith (optional) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=

# --- LangFuse ---
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL = "https://langfuse.knmholdings.org"# --- Config paths ---
# --- Config paths ---
CONFIG_PATH=./Resources/dev.yaml
MODELS_PATH=./Resources/models.yaml
MESSAGES_PATH=./Resources/messages.yaml
PROMPTS_PATH=./Resources/prompts.yaml
AGENTS_PATH=./Resources/agents.yaml
